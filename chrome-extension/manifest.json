{
  "manifest_version": 3,
  "name": "ResumeTailor Job Importer",
  "version": "0.3.2",
  "description": "Import the currently opened job posting page into ResumeTailor.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "sidePanel",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://www.linkedin.com/*",
    "https://*.indeed.com/*"
  ],
  "action": {
    "default_title": "ResumeTailor Job Importer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  }
}
